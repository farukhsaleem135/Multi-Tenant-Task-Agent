# App role — RLS is enforced; use this for all application/agent queries
DATABASE_URL=postgresql://app_user:app_password@localhost:15432/agent_db

# Admin role (postgres superuser) — bypasses RLS; use ONLY for migrations and seeding
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:15432/agent_db

# Required for evals/safety.test.ts (AI safety eval via Anthropic API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — simulates "Authorization: Bearer …" when running MCP over stdio (evals / local dev).
# Production HTTP MCP uses the Authorization header instead; same token values apply.
# Seeded tokens: dev-token-alice-tenant-a (Tenant A), dev-token-bob-tenant-b (Tenant B)
MCP_AUTH_TOKEN=dev-token-alice-tenant-a
